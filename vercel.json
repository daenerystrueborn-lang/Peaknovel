{
  "buildCommand": "pnpm install && pnpm run typecheck:libs && pnpm --filter @workspace/peak-novel run build",
  "outputDirectory": "artifacts/peak-novel/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api.railway.app/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],

  "domains": ["peaknovel.net", "www.peaknovel.net"]
}
